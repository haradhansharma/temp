---
/**
 * AdminLayout — Dedicated layout for /admin/* routes.
 *
 * Mirrors DashboardLayout.astro but with admin-specific shell:
 *   - AdminSidebar.astro (amber-accented, admin nav items)
 *   - AdminNavbar.astro (staff badge, Django admin link)
 *   - Same frozen shell pattern (h-dvh, overflow-hidden)
 *   - Different transition:persist keys to avoid conflicts with user dashboard
 *
 * This layout is exclusively used by pages under src/pages/admin/.
 * Access is gated by src/middleware.ts (is_staff check).
 */
import BaseLayout from "./BaseLayout.astro";
import AdminSidebar from "@/components/astro/AdminSidebar.astro";
import AdminNavbar from "@/components/astro/AdminNavbar.astro";
import AdminGuard from "@/components/vue/AdminGuard.vue";
import SessionGuard from "@/components/vue/SessionGuard.vue";
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Admin — SattaBase",
  description = "SattaBase administration dashboard.",
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  {
    /*
    ┌───────────────────────────────────────────────────────┐
    │  FROZEN SHELL — fills the viewport, never scrolls.    │
    │  Only the island's inner content swaps on navigation. │
    │  Uses different persist keys than user dashboard.     │
    └───────────────────────────────────────────────────────┘
  */
  }
  <div class="app-shell flex h-dvh overflow-hidden">
    <!-- ═══════════════════════════════════════════════════════
         FROZEN — Desktop Admin Sidebar (left panel)
         Persists across all admin navigations.
         ═══════════════════════════════════════════════════════ -->
    <aside
      class="app-sidebar hidden lg:flex lg:w-64 lg:flex-col lg:fixed lg:inset-y-0 z-30 bg-card/80"
      transition:persist="admin-sidebar"
    >
      <AdminSidebar />
    </aside>

    <!-- ═══════════════════════════════════════════════════════
         Mobile sidebar overlay (rebuilt on each navigation)
         ═══════════════════════════════════════════════════════ -->
    <div
      id="admin-mobile-sidebar-overlay"
      class="fixed inset-0 z-50 lg:hidden pointer-events-none"
      aria-hidden="true"
    >
      <!-- Backdrop -->
      <div
        class="fixed inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-all duration-300 z-0"
        id="admin-mobile-sidebar-backdrop"
      >
      </div>
      <!-- Panel -->
      <aside
        class="fixed inset-y-0 left-0 w-72 max-w-[85vw] bg-card shadow-2xl flex flex-col transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] z-10"
        id="admin-mobile-sidebar-panel"
        aria-label="Mobile admin sidebar"
        style="translate: -100% 0"
      >
        <!-- Close button row -->
        <div
          class="flex h-14 items-center justify-between border-b border-border px-4"
        >
          <div class="flex items-center gap-2">
            <div
              class="flex h-7 w-7 items-center justify-center rounded-lg bg-amber-600 text-white font-bold text-xs shadow-sm"
            >
              A
            </div>
            <span class="font-semibold text-sm">Sattabase Admin</span>
          </div>
          <button
            type="button"
            class="inline-flex items-center justify-center rounded-lg p-2 text-muted-foreground hover:bg-accent hover:text-foreground focus-ring transition-colors"
            id="admin-mobile-menu-close"
            aria-label="Close admin sidebar menu"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <!-- Sidebar content -->
        <div class="flex-1 overflow-y-auto">
          <AdminSidebar />
        </div>
      </aside>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         RIGHT PANEL — Topbar + Island
         ═══════════════════════════════════════════════════════ -->
    <div class="flex flex-1 flex-col min-w-0 lg:pl-64">
      <!-- FROZEN — Admin Topbar. Persists across navigations. -->
      <div class="app-topbar shrink-0" transition:persist="admin-navbar">
        <AdminNavbar />
      </div>

      <!-- ═══════════════════════════════════════════════════════
           ISLAND — Content area (rebuilt on each navigation).
           NOT persisted so the slot content swaps with new pages.
           ═══════════════════════════════════════════════════════ -->
      <main
        class="app-island flex-1 overflow-y-auto min-h-0 border rounded-[25px] border-border m-4 md:m-6 lg:m-8 bg-primary"
      >
        <div class="island-content p-4 md:p-6 lg:p-8">
          <div class="mx-auto max-w-7xl">
            <slot />
          </div>
        </div>
      </main>
    </div>
  </div>

  <!-- Session Guard: monitors auth state and redirects on session expiry -->
  <SessionGuard client:load />

  <!-- Admin Guard: enforces admin role (is_staff/owner/admin) check -->
  <!-- SECURITY: This must use client:load so it runs immediately on mount -->
  <AdminGuard client:load />
</BaseLayout>

<script>
  // astro:page-load fires on every navigation (including initial load).
  // This is critical for the mobile sidebar overlay since it is NOT
  // persisted and gets rebuilt on each navigation.
  document.addEventListener("astro:page-load", () => {
    const overlay = document.getElementById("admin-mobile-sidebar-overlay");
    const backdrop = document.getElementById("admin-mobile-sidebar-backdrop");
    const panel = document.getElementById("admin-mobile-sidebar-panel");
    const menuToggle = document.getElementById("admin-mobile-menu-toggle");
    const menuClose = document.getElementById("admin-mobile-menu-close");

    if (!overlay || !backdrop || !panel) return;

    let isOpen = false;
    let touchStartX = 0;
    let touchCurrentX = 0;
    let isSwiping = false;

    function openSidebar() {
      isOpen = true;
      overlay.classList.remove("pointer-events-none");
      overlay.setAttribute("aria-hidden", "false");
      requestAnimationFrame(() => {
        panel.style.translate = "0 0";
        backdrop.style.opacity = "1";
      });
      document.body.style.overflow = "hidden";
      menuClose?.focus();
      menuToggle?.setAttribute("aria-expanded", "true");
    }

    function closeSidebar() {
      if (!isOpen) return;
      isOpen = false;
      panel.style.translate = "-100% 0";
      backdrop.style.opacity = "0";
      menuToggle?.setAttribute("aria-expanded", "false");
      setTimeout(() => {
        overlay.classList.add("pointer-events-none");
        overlay.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";
        menuToggle?.focus();
      }, 300);
    }

    // Listen for custom event from AdminNavbar (persisted, still works)
    document.addEventListener("toggle-admin-mobile-sidebar", (e: Event) => {
      const detail = (e as CustomEvent).detail;
      if (detail?.open) {
        openSidebar();
      } else {
        closeSidebar();
      }
    });

    backdrop.addEventListener("click", closeSidebar);
    menuClose?.addEventListener("click", closeSidebar);

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        closeSidebar();
      }
    });

    // Close on resize past lg breakpoint
    const resizeObserver = new ResizeObserver(() => {
      if (window.innerWidth >= 1024 && isOpen) {
        closeSidebar();
      }
    });
    resizeObserver.observe(document.documentElement);

    // ── Swipe-to-dismiss on mobile ──
    panel.addEventListener(
      "touchstart",
      (e: Event) => {
        const touch = (e as TouchEvent).touches[0];
        touchStartX = touch.clientX;
        touchCurrentX = touch.clientX;
        isSwiping = false;
      },
      { passive: true },
    );

    panel.addEventListener(
      "touchmove",
      (e: Event) => {
        const touch = (e as TouchEvent).touches[0];
        touchCurrentX = touch.clientX;
        const diff = touchCurrentX - touchStartX;
        if (diff < -10) {
          isSwiping = true;
          const translateX = Math.max(diff, -panel.offsetWidth);
          panel.style.transition = "none";
          panel.style.translate = `${translateX}px 0`;
          const progress = Math.min(
            Math.abs(diff) / (panel.offsetWidth * 0.4),
            1,
          );
          backdrop.style.transition = "none";
          backdrop.style.opacity = String(1 - progress);
        }
      },
      { passive: true },
    );

    panel.addEventListener("touchend", () => {
      if (!isSwiping) return;
      isSwiping = false;
      panel.style.transition = "";
      backdrop.style.transition = "";
      const diff = touchCurrentX - touchStartX;
      if (diff < -panel.offsetWidth * 0.3) {
        closeSidebar();
      } else {
        panel.style.translate = "0 0";
        backdrop.style.opacity = "1";
      }
    });
  });
</script>

<style>
  /* ═══════════════════════════════════════════════════════
     ISLAND STYLING — The frozen content frame
     ═══════════════════════════════════════════════════════ */

  .app-island {
    /* Subtle amber tint for admin area */
    background-color: color-mix(
      in srgb,
      var(--color-muted) 30%,
      var(--color-bg) 70%
    );
  }

  .dark .app-island {
    background-color: color-mix(
      in srgb,
      var(--color-muted) 20%,
      var(--color-bg) 80%
    );
  }

  /* ═══════════════════════════════════════════════════════
     VIEW TRANSITIONS — Suppress all animations on frozen shell
     ═══════════════════════════════════════════════════════ */

  .app-sidebar,
  .app-topbar,
  .app-island,
  [data-astro-transition-persist] {
    view-transition-name: none !important;
  }

  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0ms !important;
  }

  /* ═══════════════════════════════════════════════════════
     ISLAND CONTENT — Subtle fade-in when content swaps
     ═══════════════════════════════════════════════════════ */
  .island-content {
    animation: island-fade-in 0.18s ease-out;
  }

  @keyframes island-fade-in {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
