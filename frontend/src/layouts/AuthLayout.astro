---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sign In — SattaBase",
  description = "Sign in to your SattaBase account.",
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-12">
    <!-- Animated gradient background -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand-50 via-background to-brand-100/50 dark:from-brand-950/40 dark:via-background dark:to-brand-900/20"></div>
    <div class="pointer-events-none absolute inset-0 opacity-30 dark:opacity-20">
      <div class="absolute -left-40 -top-40 h-80 w-80 rounded-full bg-brand-200/60 blur-3xl dark:bg-brand-800/30 animate-pulse"></div>
      <div class="absolute -bottom-32 -right-32 h-96 w-96 rounded-full bg-brand-300/40 blur-3xl dark:bg-brand-700/20 animate-pulse" style="animation-delay: 1s;"></div>
      <div class="absolute left-1/2 top-1/3 h-64 w-64 -translate-x-1/2 rounded-full bg-brand-100/50 blur-3xl dark:bg-brand-900/20 animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <!-- Main container -->
    <div class="relative z-10 flex w-full max-w-5xl flex-col items-center gap-8 lg:flex-row lg:gap-12 lg:items-stretch">

      <!-- Brand Panel (desktop only) -->
      <div class="hidden lg:flex lg:flex-1 lg:flex-col lg:items-center lg:justify-center lg:gap-10 animate-fade-in">
        <div class="flex flex-col items-center gap-8 text-center">

          <!-- SattaBase Logo Mark -->
          <div class="flex flex-col items-center gap-4">
            <div class="relative">
              <div class="flex h-20 w-20 items-center justify-center rounded-2xl gradient-brand shadow-2xl shadow-brand-500/25">
                <!-- Hub/base icon — interconnected nodes -->
                <svg class="h-11 w-11 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.264.26-2.467.732-3.558" />
                </svg>
              </div>
              <!-- Orbiting dot -->
              <div class="absolute -right-2 -top-2 flex h-7 w-7 items-center justify-center rounded-full bg-white shadow-lg dark:bg-gray-800">
                <div class="h-3 w-3 rounded-full bg-brand-500"></div>
              </div>
            </div>
            <div>
              <h2 class="text-3xl font-bold tracking-tight text-foreground">SattaBase</h2>
              <p class="mt-1 text-sm font-medium text-brand-600 dark:text-brand-400">Auth & Billing Hub</p>
            </div>
          </div>

          <!-- Description -->
          <p class="max-w-sm text-sm leading-relaxed text-muted-foreground">
            Central authentication and subscription billing for the entire
            <span class="font-semibold text-foreground">SattaSpace</span> ecosystem.
            Sign in once, access everything.
          </p>

          <!-- Ecosystem feature cards -->
          <div class="grid grid-cols-2 gap-3 max-w-xs w-full">
            <div class="flex flex-col items-center gap-1.5 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-border/50 p-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 dark:bg-brand-900/50">
                <svg class="h-4 w-4 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              </div>
              <span class="text-xs font-medium text-foreground">Authentication</span>
            </div>
            <div class="flex flex-col items-center gap-1.5 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-border/50 p-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 dark:bg-brand-900/50">
                <svg class="h-4 w-4 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                </svg>
              </div>
              <span class="text-xs font-medium text-foreground">Subscriptions</span>
            </div>
            <div class="flex flex-col items-center gap-1.5 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-border/50 p-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 dark:bg-brand-900/50">
                <svg class="h-4 w-4 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                </svg>
              </div>
              <span class="text-xs font-medium text-foreground">Billing</span>
            </div>
            <div class="flex flex-col items-center gap-1.5 rounded-xl bg-white/60 dark:bg-white/5 backdrop-blur-sm border border-border/50 p-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 dark:bg-brand-900/50">
                <svg class="h-4 w-4 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
              </div>
              <span class="text-xs font-medium text-foreground">One Dashboard</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Card -->
      <div class="w-full max-w-md animate-slide-up">
        <!-- Mobile header -->
        <div class="mb-6 flex flex-col items-center gap-2 lg:hidden">
          <div class="flex items-center gap-2.5">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg gradient-brand">
              <svg class="h-4.5 w-4.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.264.26-2.467.732-3.558" />
              </svg>
            </div>
            <span class="text-base font-bold tracking-tight text-foreground">SattaBase</span>
          </div>
          <p class="text-xs text-muted-foreground">Part of SattaSpace</p>
        </div>

        <div class="card w-full p-8 shadow-lg shadow-black/5 dark:shadow-black/20 border-border/60 dark:border-border/40">
          <slot />

          <!-- Keyboard hint -->
          <p class="sr-only">Use Tab key to navigate form fields. Press Enter to submit.</p>
        </div>

        <!-- Footer -->
        <footer class="mt-8 flex flex-col items-center gap-3 text-center text-sm text-muted-foreground">
          <a
            href="/"
            class="inline-flex items-center gap-1.5 text-muted-foreground transition-colors hover:text-foreground focus-ring rounded-md px-2 py-1"
          >
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to home
          </a>
          <p>&copy; {new Date().getFullYear()} SattaBase &middot; SattaSpace Ecosystem</p>
        </footer>
      </div>
    </div>
  </div>
</BaseLayout>
