---
interface Action {
  label: string;
  href: string;
}

interface Props {
  title: string;
  message?: string;
  icon?: "error" | "info" | "empty" | "success";
  action?: Action;
}

const {
  title,
  message = "Go back and try again.",
  icon = "error",
  action,
} = Astro.props;

const iconConfig = {
  error: {
    container: "bg-red-100 dark:bg-red-950/60",
    iconColor: "text-red-600 dark:text-red-400",
    svg: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>`,
  },
  info: {
    container: "bg-brand-100 dark:bg-brand-950/60",
    iconColor: "text-brand-600 dark:text-brand-400",
    svg: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  empty: {
    container: "bg-muted",
    iconColor: "text-muted-foreground",
    svg: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>`,
  },
  success: {
    container: "bg-brand-100 dark:bg-brand-950/60",
    iconColor: "text-brand-600 dark:text-brand-400",
    svg: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
};

const cfg = iconConfig[icon] || iconConfig.error;
---

<div class="flex flex-col items-center justify-center gap-4 py-16 animate-fade-in">
  <!-- Icon -->
  <div class={`relative flex h-20 w-20 items-center justify-center rounded-2xl ${cfg.container} transition-colors`}>
    <span class={cfg.iconColor} set:html={cfg.svg} />
    <!-- Decorative pulse ring for success -->
    {icon === "success" && (
      <span class="absolute inset-0 rounded-2xl animate-ping opacity-20 bg-brand-400"></span>
    )}
  </div>

  <!-- Text content -->
  <div class="flex flex-col items-center gap-2 text-center">
    <h3 class="text-lg font-semibold text-foreground">{title}</h3>
    <p class="text-sm text-muted-foreground max-w-sm">{message}</p>
  </div>

  <!-- Action button -->
  {action && (
    <a
      href={action.href}
      class="btn-primary mt-2"
    >
      {action.label}
    </a>
  )}

  <!-- Custom slot for additional content -->
  <slot name="extra" />
</div>
