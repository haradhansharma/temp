---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
---

<DashboardLayout title="Request Credits">
  <div class="max-w-3xl mx-auto space-y-6">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Request Credits</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Purchase credits by transferring funds to our bank account. Provide transaction details below.
      </p>
    </div>

    <!-- Bank Details Card -->
    <div id="bankDetailsCard" class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700 hidden">
        <h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Transfer to Bank Account</h2>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <p class="text-xs text-gray-500">Bank Name</p>
                <p id="bankNameDisplay" class="font-medium text-gray-900 dark:text-white"></p>
            </div>
            <div>
                <p class="text-xs text-gray-500">Account Holder</p>
                <p id="holderNameDisplay" class="font-medium text-gray-900 dark:text-white"></p>
            </div>
            <div>
                <p class="text-xs text-gray-500">Account Number</p>
                <p id="accountNumberDisplay" class="font-medium text-gray-900 dark:text-white font-mono"></p>
            </div>
            <div>
                <p class="text-xs text-gray-500">Routing Number</p>
                <p id="routingDisplay" class="font-medium text-gray-900 dark:text-white"></p>
            </div>
        </div>
    </div>

    <form id="creditRequestForm" class="bg-white dark:bg-gray-900 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 space-y-6">
        <!-- Fields ... (same as before) -->
    </form>
  </div>
</DashboardLayout>
