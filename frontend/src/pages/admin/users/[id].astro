---
/**
 * Admin User Detail — /admin/users/:id
 *
 * User detail with profile, subscriptions, and audit trail.
 * Mounts UserDetailAdmin Vue component.
 *
 * The Vue component reads the user ID from the URL path directly,
 * which is more reliable with Astro ClientRouter (View Transitions)
 * than passing it as a prop via client:only.  The prop is kept as a
 * secondary fallback for direct full-page loads.
 */
import AdminLayout from "@/layouts/AdminLayout.astro";
import UserDetailAdmin from "@/components/admin/UserDetailAdmin.vue";

const { id } = Astro.params;
const userId = Number(id);

if (!userId || isNaN(userId)) {
  return Astro.redirect("/admin/users");
}
---

<AdminLayout
  title="User Detail — Admin — SattaBase"
  description="User profile, subscriptions, and audit trail."
>
  <UserDetailAdmin client:only="vue" :userId={userId} />
</AdminLayout>

<script>
  import { useAdminGuard } from "@/composables/useAdminGuard";
</script>
